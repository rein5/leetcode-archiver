{
  "name": "leetcode-archiver",
  "version": "1.0.0",
  "description": "Firefox extension that backs up accepted LeetCode submissions to a private GitHub repository.",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "run:firefox": "web-ext run --source-dir dist",
    "package": "web-ext build --source-dir dist --overwrite-dest",
    "sign": "web-ext sign --source-dir dist --channel listed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rein5/leetcode-archiver.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rein5/leetcode-archiver/issues"
  },
  "homepage": "https://github.com/rein5/leetcode-archiver#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "web-ext": "^10.1.0",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.10.5",
    "preact": "^10.29.1"
  }
}
