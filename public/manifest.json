{
  "manifest_version": 2,
  "name": "LeetCode Archiver",
  "version": "0.1.1",
  "description": "Automatically backs up accepted LeetCode submissions to a private GitHub repository.",

  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "*://leetcode.com/*",
    "*://api.github.com/*"
  ],

  "background": {
    "scripts": ["background/index.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["*://leetcode.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "LeetCode Archiver"
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "leetcode-archiver@rein5",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
